{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/agility-game/scenarios-management/main/schemas/scenario.schema.json",
  "title": "Agility Game Scenario",
  "description": "Schema for playable Agility Game scenarios, including katas, buggy codebases, missions, scoring, spaces, and required capabilities.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "type",
    "difficulty",
    "source",
    "spaces",
    "required_capabilities",
    "missions",
    "success_criteria"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "examples": ["gilded-rose-python"]
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "type": {
      "type": "string",
      "enum": ["kata", "buggy-codebase", "case-study", "simulation", "workshop", "challenge"]
    },
    "language": {
      "type": "string",
      "examples": ["python"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },
    "summary": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["embedded", "github", "external", "generated"]
        },
        "upstream_repository": {
          "type": "string",
          "examples": ["emilybache/GildedRose-Refactoring-Kata"]
        },
        "upstream_path": {
          "type": "string",
          "examples": ["python"]
        },
        "local_path": {
          "type": "string",
          "examples": ["source/gilded-rose-python"]
        },
        "license": {
          "type": "string"
        }
      }
    },
    "spaces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": {
          "$ref": "#/definitions/slugList"
        },
        "supporting": {
          "$ref": "#/definitions/slugList"
        }
      }
    },
    "required_capabilities": {
      "$ref": "#/definitions/slugList"
    },
    "recommended_roles": {
      "$ref": "#/definitions/slugList"
    },
    "missions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "objective"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^mission-[0-9]{2}(?:-[a-z0-9]+)*$"
          },
          "title": {
            "type": "string"
          },
          "objective": {
            "type": "string"
          },
          "spaces": {
            "$ref": "#/definitions/slugList"
          },
          "required_capabilities": {
            "$ref": "#/definitions/slugList"
          },
          "success_criteria": {
            "$ref": "#/definitions/stringList"
          }
        }
      }
    },
    "success_criteria": {
      "$ref": "#/definitions/stringList"
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_points": {
          "type": "integer",
          "minimum": 0
        },
        "dimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "points"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "name": {
                "type": "string"
              },
              "points": {
                "type": "integer",
                "minimum": 0
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "test_command": {
          "type": "string",
          "examples": ["python -m unittest"]
        },
        "working_directory": {
          "type": "string",
          "examples": ["source/gilded-rose-python"]
        }
      }
    }
  },
  "definitions": {
    "slugList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
