{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/agility-game/scenarios-management/main/schemas/scenario.schema.json",
  "title": "Agility Game Scenario",
  "description": "Schema for playable Agility Game scenarios.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "type",
    "difficulty",
    "source",
    "spaces",
    "missions",
    "success_criteria"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },

    "schema_version": {
      "type": "string",
      "examples": ["1.0.0"]
    },

    "id": {
      "$ref": "#/$defs/slug"
    },

    "title": {
      "type": "string",
      "minLength": 3
    },

    "summary": {
      "type": "string"
    },

    "type": {
      "type": "string",
      "enum": [
        "kata",
        "buggy-codebase",
        "simulation",
        "case-study",
        "challenge"
      ]
    },

    "language": {
      "type": "string"
    },

    "difficulty": {
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "advanced",
        "expert"
      ]
    },

    "tags": {
      "$ref": "#/$defs/stringList"
    },

    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "github",
            "embedded",
            "external",
            "generated"
          ]
        },

        "upstream_repository": {
          "type": "string"
        },

        "upstream_path": {
          "type": "string"
        },

        "local_path": {
          "type": "string"
        },

        "license": {
          "type": "string"
        }
      }
    },

    "spaces": {
      "type": "object",
      "required": ["primary"],
      "additionalProperties": false,
      "properties": {
        "primary": {
          "$ref": "#/$defs/slugList"
        },

        "supporting": {
          "$ref": "#/$defs/slugList"
        }
      }
    },

    "required_capabilities": {
      "$ref": "#/$defs/slugList"
    },

    "recommended_roles": {
      "$ref": "#/$defs/slugList"
    },

    "recommended_ai_employees": {
      "$ref": "#/$defs/slugList"
    },

    "learning_objectives": {
      "$ref": "#/$defs/stringList"
    },

    "missions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/mission"
      }
    },

    "success_criteria": {
      "$ref": "#/$defs/stringList"
    },

    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "working_directory": {
          "type": "string"
        },

        "test_command": {
          "type": "string"
        }
      }
    },

    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "$ref": "#/$defs/stringList"
        },

        "success_exit_codes": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      }
    },

    "gameplay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "estimated_duration_minutes": {
          "type": "integer",
          "minimum": 1
        },

        "single_player": {
          "type": "boolean"
        },

        "multiplayer": {
          "type": "boolean"
        },

        "recommended_team_size": {
          "type": "integer",
          "minimum": 1
        }
      }
    },

    "complexity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "estimated_files": {
          "type": "integer"
        },

        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    }
  },

  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },

    "slugList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slug"
      },
      "uniqueItems": true
    },

    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "mission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "objective"
      ],
      "properties": {
        "id": {
          "type": "string"
        },

        "title": {
          "type": "string"
        },

        "objective": {
          "type": "string"
        },

        "spaces": {
          "$ref": "#/$defs/slugList"
        },

        "required_capabilities": {
          "$ref": "#/$defs/slugList"
        },

        "success_criteria": {
          "$ref": "#/$defs/stringList"
        }
      }
    }
  }
}
